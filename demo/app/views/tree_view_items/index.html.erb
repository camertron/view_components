<%= render(Primer::Alpha::TreeView::SubTree.new(level: path.size, path: path, expanded: true)) do |tree| %>
  <% entries.each do |label, type| %>
    <% case type %>
    <% when :directory %>
      <% tree.with_sub_tree(label: label) do |sub_tree| %>
        <% sub_tree.with_leading_visual_icons do |icons| %>
          <% icons.with_expanded_icon(icon: :"file-directory-open-fill") %>
          <% icons.with_collapsed_icon(icon: :"file-directory-fill") %>
        <% end %>

        <% if loader == :skeleton %>
          <% sub_tree.with_loading_skeleton(src: tree_view_items_path(loader: "skeleton")) %>
        <% else %>
          <% sub_tree.with_loading_spinner(src: tree_view_items_path(loader: "spinner")) %>
        <% end %>
      <% end %>
    <% when :file %>
      <% tree.with_item(label: label) do |item| %>
        <% item.with_leading_visual_icon(icon: :file) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
