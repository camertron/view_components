<%= render(Primer::Alpha::TreeView::Node.new(**@system_arguments)) do |node| %>
  <% if leading_visual? %>
    <% node.with_leading_visual do %>
      <%= leading_visual %>
    <% end %>
  <% end %>
  <% if trailing_visual? %>
    <% node.with_trailing_visual do %>
      <%= trailing_visual %>
    <% end %>
  <% end %>
  <% node.with_text_content { @label } %>
<% end %>
